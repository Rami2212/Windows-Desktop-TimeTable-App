<Window x:Class="TimeTableApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TimeTableApp.ViewModels"
        Title="Weekly Habit Tracker"
        Height="700"
        Width="1400">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:DayColumnViewModel}">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="8">
                <StackPanel>

                    <TextBlock Text="{Binding DayName}" FontSize="16" FontWeight="Bold"/>

                    <DataGrid ItemsSource="{Binding DayTasks}"
                              AutoGenerateColumns="False"
                              Height="400">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Task" Binding="{Binding TaskName}"/>
                            <DataGridTextColumn Header="Points" Binding="{Binding Points}"/>
                            <DataGridCheckBoxColumn Header="Done"
                                Binding="{Binding IsDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>

                    </DataGrid>

                    <TextBlock Text="{Binding TotalCompletedPoints, StringFormat=Completed: {0}}"/>
                    <TextBlock Text="{Binding TotalPossiblePoints, StringFormat=Total: {0}}"/>

                    <!-- FIXED -->
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}"/>

                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <ItemsControl ItemsSource="{Binding Days}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</Window>