<Window x:Class="TimeTableApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TimeTableApp.ViewModels"
        xmlns:conv="clr-namespace:TimeTableApp.Converters"
        xmlns:behaviors="clr-namespace:TimeTableApp.Behaviors"
        mc:Ignorable="d"
        Title="Time Table"
        Height="900" Width="1700"
        Icon="/Assets/app.ico"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F6F7">

    <Window.Resources>
        <conv:BelowEightyConverter x:Key="BelowEightyConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Brushes ───────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="WindowBrush"     Color="#F5F6F7"/>
        <SolidColorBrush x:Key="PanelBrush"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#D6D9DE"/>
        <SolidColorBrush x:Key="HeaderBrush"     Color="#F3F4F6"/>
        <SolidColorBrush x:Key="ToolbarBrush"    Color="#FAFAFA"/>
        <SolidColorBrush x:Key="TextBrush"       Color="#111827"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#2563EB"/>
        <SolidColorBrush x:Key="DangerBrush"     Color="#DC2626"/>

        <!-- ── Shared button styles ──────────────────────────────────────── -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style x:Key="RemoveButtonStyle" TargetType="Button">
            <Setter Property="Width"               Value="18"/>
            <Setter Property="Height"              Value="18"/>
            <Setter Property="Padding"             Value="0"/>
            <Setter Property="Margin"              Value="0"/>
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Foreground"          Value="#B91C1C"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="FontWeight"          Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>

        <!-- ── TextBox styles ───────────────────────────────────────────── -->
        <Style x:Key="TaskTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness"               Value="0"/>
            <Setter Property="Background"                    Value="Transparent"/>
            <Setter Property="Padding"                       Value="2,0,2,0"/>
            <Setter Property="Margin"                        Value="0"/>
            <Setter Property="VerticalContentAlignment"      Value="Center"/>
            <Setter Property="Height"                        Value="30"/>
            <Setter Property="TextWrapping"                  Value="NoWrap"/>
            <Setter Property="AcceptsReturn"                 Value="False"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <Style x:Key="PointsTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness"               Value="0"/>
            <Setter Property="Background"                    Value="Transparent"/>
            <Setter Property="Padding"                       Value="0"/>
            <Setter Property="Margin"                        Value="0"/>
            <Setter Property="HorizontalContentAlignment"    Value="Center"/>
            <Setter Property="VerticalContentAlignment"      Value="Center"/>
            <Setter Property="Height"                        Value="30"/>
            <Setter Property="TextWrapping"                  Value="NoWrap"/>
            <Setter Property="AcceptsReturn"                 Value="False"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <Style x:Key="LabelInputStyle" TargetType="TextBox">
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Padding"                  Value="6,4"/>
            <Setter Property="Margin"                   Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>

        <!-- ── CheckBox ─────────────────────────────────────────────────── -->
        <Style x:Key="CenteredCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment"        Value="Center"/>
            <Setter Property="VerticalAlignment"          Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Margin"  Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="16" Height="16"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="14" Height="14"
                                    Background="White" BorderBrush="#6B7280" BorderThickness="1"/>
                            <Path x:Name="CheckMark" Width="8" Height="6"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Stroke="#2563EB" StrokeThickness="2"
                                  Stretch="Fill" Data="M 0 3 L 3 6 L 8 0"
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Progress bar ─────────────────────────────────────────────── -->
        <Style x:Key="FlatProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height"          Value="7"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background"      Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ── Day panel border ─────────────────────────────────────────── -->
        <Style x:Key="DayPanelStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="CornerRadius"    Value="6"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
             DayColumnViewModel DataTemplate
             Shared by the 7 day columns AND the To Do column.
        ═══════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:DayColumnViewModel}">
            <Border Style="{StaticResource DayPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <!-- day title -->
                        <RowDefinition Height="34"/>
                        <!-- col headers -->
                        <RowDefinition Height="*"/>
                        <!-- task rows -->
                        <RowDefinition Height="Auto"/>
                        <!-- completed pts -->
                        <RowDefinition Height="Auto"/>
                        <!-- total pts -->
                        <RowDefinition Height="Auto"/>
                        <!-- progress bar -->
                        <RowDefinition Height="38"/>
                        <!-- add-row footer -->
                    </Grid.RowDefinitions>

                    <!-- Day title -->
                    <Border Grid.Row="0"
                            Background="{StaticResource ToolbarBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0"
                            Padding="8,0">
                        <TextBlock Text="{Binding DayName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- Column headers -->
                    <Grid Grid.Row="1" Background="{StaticResource HeaderBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <!-- drag handle -->
                            <ColumnDefinition Width="*"/>
                            <!-- task name -->
                            <ColumnDefinition Width="36"/>
                            <!-- points -->
                            <ColumnDefinition Width="30"/>
                            <!-- done -->
                            <ColumnDefinition Width="22"/>
                            <!-- delete -->
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="5"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"/>
                        <TextBlock Grid.Column="1"
                                   FontFamily="Segoe MDL2 Assets" Text="&#xE8FD;"
                                   FontSize="13" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextBrush}"/>
                        <TextBlock Grid.Column="2"
                                   FontFamily="Segoe MDL2 Assets" Text="&#xEC42;"
                                   FontSize="13" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextBrush}"/>
                        <TextBlock Grid.Column="3"
                                   FontFamily="Segoe MDL2 Assets" Text="&#xE73E;"
                                   FontSize="13" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextBrush}"/>
                    </Grid>

                    <!-- Scrollable task rows + drag-drop wired via behavior -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DayTasks}"
                                      behaviors:DragDropBehavior.IsEnabled="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="34" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <!-- drag handle -->
                                            <ColumnDefinition Width="*"/>
                                            <!-- task name -->
                                            <ColumnDefinition Width="36"/>
                                            <!-- points -->
                                            <ColumnDefinition Width="30"/>
                                            <!-- done -->
                                            <ColumnDefinition Width="22"/>
                                            <!-- delete -->
                                        </Grid.ColumnDefinitions>

                                        <!-- row separator -->
                                        <Border Grid.ColumnSpan="5"
                                                BorderBrush="#ECEEF2"
                                                BorderThickness="0,0,0,1"
                                                VerticalAlignment="Stretch"/>

                                        <!-- ⠿ Drag handle (six-dot grip) -->
                                        <TextBlock x:Name="DragHandle"
                                                   Grid.Column="0"
                                                   Text="⠿"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#C4C9D4"
                                                   Cursor="SizeAll"
                                                   ToolTip="Drag to reorder"/>

                                        <!-- Task name – fixed height, no wrap -->
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding TaskName, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TaskTextBoxStyle}"
                                                 VerticalAlignment="Center"/>

                                        <!-- Points -->
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Points, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PointsTextBoxStyle}"
                                                 VerticalAlignment="Center"/>

                                        <!-- Done -->
                                        <CheckBox Grid.Column="3"
                                                  IsChecked="{Binding IsDone, Mode=TwoWay,
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource CenteredCheckBoxStyle}"
                                                  VerticalAlignment="Center"/>

                                        <!-- Remove -->
                                        <Button Grid.Column="4" Content="×"
                                                Style="{StaticResource RemoveButtonStyle}"
                                                Command="{Binding DataContext.RemoveRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Completed points -->
                    <TextBlock Grid.Row="3"
                               Margin="8,8,8,1" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="{Binding TotalCompletedPoints,
                                      StringFormat='Completed: {0} pts'}"/>

                    <!-- Total points (red + warning when < 10, hidden for To Do) -->
                    <TextBlock Grid.Row="4" Margin="8,0,8,6" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBelowMinPoints}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Total: {0} pts">
                                <Binding Path="TotalPossiblePoints"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Progress bar (red when below 80%) -->
                    <StackPanel Grid.Row="5" Margin="8,0,8,8">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding ProgressValue, Mode=OneWay}">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar"
                                       BasedOn="{StaticResource FlatProgressBarStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBelowProgressThreshold}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Right" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBelowProgressThreshold}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:F0}%">
                                    <Binding Path="ProgressValue"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Add-row footer -->
                    <Border Grid.Row="6"
                            Background="{StaticResource ToolbarBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,6,6"
                            Padding="8,5">
                        <Button Content="+ Add Row"
                                Command="{Binding AddRowCommand}"
                                Style="{StaticResource AddButtonStyle}"
                                HorizontalAlignment="Left"
                                Width="80"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <!-- ═════════════════════════════════════════════════════════════════════
         ROOT LAYOUT
    ═════════════════════════════════════════════════════════════════════ -->
    <DockPanel Background="{StaticResource WindowBrush}">

        <!-- App bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       Text="Time Table"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Vertical split:  5/6 tasks area  |  1/6 bottom panel
        ═══════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="1*" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- ── Top tasks area  (To Do first, then 7 day columns) ───── -->
            <ScrollViewer Grid.Row="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="6,6,6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- To Do column — slightly wider -->
                        <ColumnDefinition Width="1.15*"/>
                        <!-- 7 day columns -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- To Do column (index 0) -->
                    <ContentPresenter Grid.Column="0"
                                      Content="{Binding ToDoColumn}"/>

                    <!-- 7 day columns (index 1-7) -->
                    <ItemsControl Grid.Column="1" Grid.ColumnSpan="7"
                                  ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- ── Bottom panel  (Weekly Stats + Period Labels) ─────────── -->
            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Weekly Stats ──────────────────────────────── -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="Weekly Stats"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>

                        <!-- Total points card -->
                        <Border Background="{StaticResource HeaderBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,8,0"
                                MinWidth="160">
                            <StackPanel>
                                <TextBlock Text="Total Points"
                                           FontSize="11"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Margin="0,0,0,2"/>
                                <!-- Points number — red when below weekly minimum (70) -->
                                <TextBlock FontSize="22" FontWeight="Bold"
                                           Text="{Binding WeeklyStats.WeeklyTotalPoints}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WeeklyStats.IsBelowWeeklyMinPoints}"
                                                             Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Warning label -->
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource DangerBrush}"
                                           Text="{Binding WeeklyStats.WeeklyMinLabel}"
                                           Visibility="{Binding WeeklyStats.IsBelowWeeklyMinPoints,
                                                        Converter={StaticResource BoolToVis}}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Completed points card -->
                        <Border Background="{StaticResource HeaderBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,8" Margin="0,0,8,0"
                                MinWidth="170">
                            <StackPanel>
                                <TextBlock Text="Completed Points"
                                           FontSize="11"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="{Binding WeeklyStats.WeeklyCompletedPoints}"/>
                            </StackPanel>
                        </Border>

                        <!-- Weekly progress card -->
                        <Border Background="{StaticResource HeaderBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,8"
                                MinWidth="190">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Weekly Progress"
                                               FontSize="11"
                                               Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WeeklyStats.WeeklyProgressValue,
                                                                           Converter={StaticResource BelowEightyConverter}}"
                                                                 Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:F0}%">
                                                <Binding Path="WeeklyStats.WeeklyProgressValue"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DockPanel>
                                <ProgressBar Minimum="0" Maximum="100"
                                             Value="{Binding WeeklyStats.WeeklyProgressValue, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar"
                                               BasedOn="{StaticResource FlatProgressBarStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WeeklyStats.WeeklyProgressValue,
                                                                       Converter={StaticResource BelowEightyConverter}}"
                                                             Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Period Labels ─────────────────────────────── -->
                    <StackPanel Grid.Column="1"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center">

                        <TextBlock Text="Period Labels"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Day"
                                       FontSize="11"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding WeeklyStats.DayLabel, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LabelInputStyle}"
                                     LostFocus="OnLabelLostFocus"
                                     ToolTip="Name for the day (e.g. Learning day)"
                                     Margin="0,0,12,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="Week"
                                       FontSize="11"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding WeeklyStats.WeekLabel, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LabelInputStyle}"
                                     LostFocus="OnLabelLostFocus"
                                     ToolTip="Name for the week"
                                     Margin="0,0,12,0"/>

                            <TextBlock Grid.Column="4"
                                       Text="Month"
                                       FontSize="11"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="5"
                                     Text="{Binding WeeklyStats.MonthLabel, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LabelInputStyle}"
                                     LostFocus="OnLabelLostFocus"
                                     ToolTip="Name for the month"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>